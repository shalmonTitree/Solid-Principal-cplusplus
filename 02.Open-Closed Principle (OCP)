#include <iostream>
using namespace std;

class Payment {
public:
    virtual void pay() = 0;
};

class CreditCard : public Payment {
public:
    void pay() override {
        cout << "Paid using Credit Card\n";
    }
};

class UPI : public Payment {
public:
    void pay() override {
        cout << "Paid using UPI\n";
    }
};

int main() {
    Payment* p = new UPI();
    p->pay();

    delete p;
}
